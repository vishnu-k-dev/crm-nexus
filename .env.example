# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# TigerGraph Cloud (free tier)
TG_HOST=https://your-instance.i.tgcloud.io
TG_USERNAME=tigergraph
TG_PASSWORD=
TG_GRAPH=TechProbe
TG_TOKEN=

# GitHub (unauthenticated works for public repos but with low rate-limit; use a PAT for the bench)
GITHUB_TOKEN=

# API server
PORT=3001
NODE_ENV=development

# Models (do not change unless you know why — fair comparison depends on this)
GEN_MODEL=claude-haiku-4-5-20251001
JUDGE_MODEL=claude-sonnet-4-6

# Bench
BENCH_DB_PATH=./data/bench.sqlite
EVAL_SET_PATH=./data/eval_set.json
SEED_GRAPH_PATH=./data/seed_graph.json
