{
  "name": "creda-graphrag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TechProbe AI — TigerGraph GraphRAG vs baseline LLM head-to-head, for the TigerGraph GraphRAG Inference Hackathon 2026.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch apps/api/src/server.ts",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/api run build && npm --workspace apps/web run build",
    "download-wiki": "tsx scripts/download-wiki.ts",
    "generate-eval": "tsx scripts/generate-eval.ts",
    "ingest-wiki": "tsx scripts/ingest-wiki.ts",
    "tg:up": "docker compose --project-directory ../tg-graphrag-repo up -d",
    "tg:down": "docker compose --project-directory ../tg-graphrag-repo down",
    "tg:logs": "docker compose --project-directory ../tg-graphrag-repo logs -f graphrag",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "openai": "^6.35.0"
  }
}
